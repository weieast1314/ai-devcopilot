{
  "version": "1.1.0",
  "capabilities": {
    "file.read": {
      "description": "读取项目文件与文档内容"
    },
    "file.write": {
      "description": "修改或创建项目内文件"
    },
    "shell.exec": {
      "description": "执行本地命令、Git、构建与部署命令"
    },
    "mcp.lark": {
      "description": "通过飞书 MCP 读取文档内容与元数据"
    },
    "web.fetch": {
      "description": "通过 HTTP 抓取网页或文档内容"
    },
    "interaction.ask_followup": {
      "description": "向用户发起结构化选项确认"
    },
    "state.persistence": {
      "description": "在会话之间持久化流程状态"
    },
    "code.review": {
      "description": "执行代码审查或读取审查结果"
    },
    "skill.superpowers.available": {
      "description": "可调用 using-superpowers 进行会话级预检"
    },
    "skill.superpowers.brainstorming": {
      "description": "可调用 superpowers 的 brainstorming 能力"
    },
    "skill.superpowers.writing-plans": {
      "description": "可调用 superpowers 的 writing-plans 能力"
    },
    "skill.superpowers.executing-plans": {
      "description": "可调用 superpowers 的 executing-plans 能力"
    },
    "skill.superpowers.test-driven-development": {
      "description": "可调用 superpowers 的 test-driven-development 能力"
    },
    "skill.superpowers.systematic-debugging": {
      "description": "可调用 superpowers 的 systematic-debugging 能力"
    },
    "skill.superpowers.verification-before-completion": {
      "description": "可调用 superpowers 的 verification-before-completion 能力"
    },
    "skill.superpowers.code-review": {
      "description": "可调用 superpowers 的 requesting/receiving-code-review 能力"
    },
    "skill.superpowers.finishing-branch": {
      "description": "可调用 superpowers 的 finishing-a-development-branch 能力"
    }
  },
  "targets": {
    "pipelines": {
      "dev-flow": {
        "requiredAll": [
          "file.read",
          "file.write",
          "skill.superpowers.available"
        ],
        "optional": [
          "shell.exec",
          "mcp.lark",
          "web.fetch",
          "interaction.ask_followup",
          "state.persistence",
          "code.review"
        ],
        "phaseRequired": {
          "planning": [
            "skill.superpowers.brainstorming",
            "skill.superpowers.writing-plans"
          ],
          "implementation": [
            "skill.superpowers.executing-plans",
            "skill.superpowers.test-driven-development",
            "skill.superpowers.systematic-debugging"
          ],
          "verification": [
            "shell.exec",
            "skill.superpowers.verification-before-completion",
            "skill.superpowers.code-review"
          ],
          "delivery": [
            "shell.exec",
            "skill.superpowers.finishing-branch"
          ]
        }
      },
      "hotfix-flow": {
        "requiredAll": [
          "file.read",
          "file.write",
          "skill.superpowers.available"
        ],
        "optional": [
          "shell.exec",
          "interaction.ask_followup",
          "state.persistence",
          "code.review"
        ],
        "phaseRequired": {
          "implementation": [
            "skill.superpowers.executing-plans",
            "skill.superpowers.test-driven-development",
            "skill.superpowers.systematic-debugging"
          ],
          "verification": [
            "shell.exec",
            "skill.superpowers.verification-before-completion",
            "skill.superpowers.code-review"
          ],
          "delivery": [
            "shell.exec",
            "skill.superpowers.finishing-branch"
          ]
        }
      }
    },
    "composites": {
      "requirement-fetch": {
        "requiredAll": [
          "file.read"
        ],
        "requiredAnyOf": [
          [
            "mcp.lark"
          ],
          [
            "web.fetch"
          ]
        ],
        "optional": [
          "interaction.ask_followup"
        ]
      },
      "writing-plans": {
        "requiredAll": [
          "file.read",
          "skill.superpowers.brainstorming",
          "skill.superpowers.writing-plans",
          "interaction.ask_followup",
          "state.persistence"
        ],
        "optional": []
      },
      "executing-plans": {
        "requiredAll": [
          "file.read",
          "file.write",
          "skill.superpowers.executing-plans",
          "skill.superpowers.test-driven-development",
          "skill.superpowers.systematic-debugging",
          "interaction.ask_followup"
        ],
        "optional": [
          "shell.exec"
        ]
      },
      "code-verification": {
        "requiredAll": [
          "shell.exec",
          "skill.superpowers.verification-before-completion",
          "skill.superpowers.code-review",
          "code.review",
          "interaction.ask_followup"
        ],
        "optional": []
      },
      "code-delivery": {
        "requiredAll": [
          "shell.exec",
          "skill.superpowers.finishing-branch",
          "interaction.ask_followup"
        ],
        "optional": []
      }
    },
    "atoms": {
      "feishu-doc-fetch": {
        "requiredAnyOf": [
          [
            "mcp.lark"
          ],
          [
            "web.fetch"
          ]
        ],
        "optional": []
      }
    }
  }
}
